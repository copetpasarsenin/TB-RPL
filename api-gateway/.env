# =============================================
# API Gateway Configuration
# =============================================

# Server
APP_PORT=8080
APP_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=api_gateway
DB_SSLMODE=disable

# JWT Secret Key
JWT_SECRET=your-super-secret-key-change-in-production

# Gateway Fee (0.5% sesuai aturan keuangan)
GATEWAY_FEE_PERCENT=0.5

# SmartBank Integration
SMARTBANK_BASE_URL=http://localhost:8081

# Service URLs (kelompok lain)
MARKETPLACE_BASE_URL=http://localhost:8082
POS_BASE_URL=http://localhost:8083
LOGISTIKITA_BASE_URL=http://localhost:8084
SUPPLIERHUB_BASE_URL=http://localhost:8085
UMKM_INSIGHT_BASE_URL=http://localhost:8086

# Rate Limiting
RATE_LIMIT_PER_SECOND=10
COOLDOWN_SECONDS=10

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/gateway.log
